{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "types": ["fvtt-types"],

    /* Bundler mode */
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": false,
    "paths": {
      "@src/*": ["./src/*"],
      "@app": ["./src/OscSheet/app"],
      "@app/*": ["./src/OscSheet/app/*"],
      "@layout": ["./src/OscSheet/layout"],
      "@layout/*": ["./src/OscSheet/layout/*"],
      "@features": ["./src/OscSheet/features"],
      "@features/*": ["./src/OscSheet/features/*"],
      "@domain": ["./src/OscSheet/domain"],
      "@domain/*": ["./src/OscSheet/domain/*"],
      "@ui": ["./src/OscSheet/components/ui"],
      "@ui/*": ["./src/OscSheet/components/ui/*"]
    }
  },
  // tools/e2e is a standalone Playwright package compiled by its own toolchain.
  "exclude": ["tools"]
}
